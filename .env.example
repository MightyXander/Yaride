BOT_TOKEN=
DB_PATH=yaride.db

# Опциональные UX-константы (см. app/config.py). Значения по умолчанию устраивают.
# SEATS_CHOICES=2,3,4
# PRICE_CHOICES=100,150,200
# TIME_STEP_MINUTES=30
# WORK_HOURS_START=6
# WORK_HOURS_END=23
# GEO_SUGGEST_LIMIT=5
# GEO_SUGGEST_MAX_KM=85.0
# LOCALITY_GEO_MAX_KM=150.0
# RATING_PROMPT_INITIAL_DELAY_S=45
# RATING_PROMPT_INTERVAL_S=180

# --- Веб-админка (модуль admin/) ---
# Постоянный секрет cookie-сессий. Без него сессии сбрасываются при каждом рестарте.
# ADMIN_SESSION_SECRET=
# Адрес и порт локального веб-интерфейса.
# ADMIN_HOST=127.0.0.1
# ADMIN_PORT=8000
# Слать ли уведомления пользователям через бота при действиях админа (отмена поездки, бан).
# Требует валидного BOT_TOKEN. По умолчанию включено, если токен задан.
# ADMIN_NOTIFY_USERS=true
